{
    // Use the root directory for configuration
    // any overriding configs defined here
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
      "target": "ES6",
      "module": "commonjs",
      "sourceMap": true,
      "lib": ["ESNext"],
      "paths": {
        "@shared/*": ["../../shared/*"],
        "*": ["./*"]
      },
      "types": ["node"]
    },
    "include": ["src/**/*", "prisma/**/*"],
      "ts-node": {
    "transpileOnly": true
  },
    "exclude": ["node_modules", "dist"]
}